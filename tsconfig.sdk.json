{
    "compilerOptions": {
        "target": "ES2022",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "moduleResolution": "bundler",
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "types": ["vite/client", "vitest/globals"]
    },
    "include": [
        "resources/sdk/**/*.ts",
        "resources/sdk/**/*.vue",
        "resources/js/vue-shim.d.ts",
        "tests/sdk/**/*.ts",
        "vite.sdk.config.ts",
        "vitest.config.ts"
    ]
}
