{
    "name": "weblexai/community-edition",
    "description": "Self-hosted website translation management and delivery.",
    "license": "Apache-2.0",
    "type": "project",
    "keywords": [
        "translation",
        "localization",
        "self-hosted"
    ],
    "require": {

        "cyrildewit/eloquent-viewable": "^7.0",
        "filament/filament": "^4.0",
        "filament/spatie-laravel-media-library-plugin": "^4.0",
        "filament/spatie-laravel-settings-plugin": "^4.0",
        "geoip2/geoip2": "^2.1",
        "google/cloud-translate": "^2.1",
        "inertiajs/inertia-laravel": "^2.0",
        "laravel/ai": "^0.4.4",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.45",
        "laravel/octane": "^2.13",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "laravel/wayfinder": "^0.1.13",
        "league/flysystem-aws-s3-v3": "^3.30",
        "maatwebsite/excel": "^3.1",
        "opcodesio/log-viewer": "^3.24.2",
        "spatie/laravel-activitylog": "^4.10",
        "spatie/laravel-medialibrary": "^11.13",
        "spatie/laravel-permission": "^6.23",
        "spatie/laravel-query-builder": "^6.3",
        "spatie/laravel-settings": "^3.6",
        "spatie/laravel-sluggable": "^3.7",
        "stechstudio/laravel-zipstream": "^5.7",
        "tightenco/ziggy": "^2.4",
        "torann/geoip": "^3.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.0",
        "driftingly/rector-laravel": "^2.5",
        "ergebnis/composer-normalize": "^2.52",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.10",
        "laravel/boost": "^2.4",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.18",
        "laravel/sail": "^1.51",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^2.2",
        "rector/rector": "^2.4"
    },

    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "bootstrap/helper-functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },

    "scripts": {
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "analyse": [
            "phpstan analyse --memory-limit=1G"
        ],
        "arch": [
            "pest --arch"
        ],
        "composer:normalize": [
            "composer normalize"
        ],
        "composer:normalize:check": [
            "composer normalize --dry-run"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "dev:ssr": [
            "npm run build:ssr",
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"php artisan inertia:start-ssr\" --names=server,queue,logs,ssr --kill-others"
        ],
        "quality": [
            "@composer validate --no-check-publish --check-lock",
            "@composer:normalize:check",
            "pint --test",
            "@analyse",
            "@rector:check",
            "@arch",
            "@type-coverage",
            "@test",
            "npm run lint:check",
            "npm run format:check",
            "npm run typecheck",
            "npm run test:sdk",
            "npm run build"
        ],
        "rector:check": [
            "rector process --dry-run --no-progress-bar"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "php -d memory_limit=1G vendor/bin/pest"
        ],
        "type-coverage": [
            "pest --type-coverage --min=90 --compact --memory-limit=1G"
        ]
    },
    "$schema": "https://getcomposer.org/schema.json"
}
