includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 1
    paths:
        - app
    excludePaths:
        analyse:
            - app/Filament/*
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        - identifier: property.notFound
        - identifier: staticMethod.notFound
        - identifier: function.notFound
